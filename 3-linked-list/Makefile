# ==============================================================================
# 定義基本變數
# ==============================================================================
CC = gcc

# 基本編譯選項：-Wall -Wextra 啟用全面警告
CFLAGS = -Wall -Wextra 

# 定義目標可執行檔名稱與所需的相依目的檔 (.o)
EXEC = linked_list.out
OBJS = main.o list.o

# 宣告虛擬目標 (Phony Targets)
.PHONY: all debug run clean help

# ==============================================================================
# Target-specific Variable Values
# ==============================================================================
# all 啟用 -O2 最佳化；debug 啟用 -g 且關閉最佳化 (-O0)
all: CFLAGS += -O2
debug: CFLAGS += -g -O0

# ==============================================================================
# 建置規則
# ==============================================================================

# 1. all: 預設目標，以最佳化選項建置可執行檔
all: $(EXEC)

# 2. debug: 以除錯選項建置可執行檔
debug: $(EXEC)

# 連結階段：將所有的 .o 檔案連結成最终的可執行檔
# $^ 代表所有相依檔案 (即 main.o list.o)
# $@ 代表目標檔案 (即 linked_list.out)
$(EXEC): $(OBJS)
	$(CC) $(CFLAGS) $^ -o $@

# 隱式規則 (Implicit Rules) 的具體化：將個別的 .c 編譯成 .o
# $< 代表第一個相依檔案 (.c 原始碼)
main.o: main.c list.h
	$(CC) $(CFLAGS) -c main.c -o main.o

list.o: list.c list.h
	$(CC) $(CFLAGS) -c list.c -o list.o

# ==============================================================================
# 執行與清理規則
# ==============================================================================

# 3. run: 執行編譯出來的程式
run: all
	@echo "--- Running $(EXEC) ---"
	./$(EXEC)

# 4. clean: 清除編譯產生的目的檔與可執行檔
clean:
	rm -f $(OBJS) $(EXEC)

# 5. help: 顯示使用說明
help:
	@echo "========================================================"
	@echo " Makefile for Exercise 3: Linked List"
	@echo "========================================================"
	@echo " 支援的指令選項："
	@echo "  make 或 make all : 開啟 -O2 最佳化編譯並建置程式"
	@echo "  make debug       : 包含 -g 除錯資訊並關閉最佳化進行編譯"
	@echo "  make run         : 自動編譯並執行可執行檔"
	@echo "  make clean       : 清除所有產生的 .o 目的檔與可執行檔"
	@echo "  make help        : 顯示此說明訊息"
	@echo "========================================================"