# ==============================================================================
# 定義變數 
# ==============================================================================
CC = gcc
CFLAGS = -Wall -Wextra
LDFLAGS = -lm

# 偵測目錄下所有的 .c 檔案 
SRCS = $(wildcard *.c)

# 將所有的 .c 檔名替換為對應的 .out 執行檔名 (e.g., area.c -> area.out)
EXECS = $(SRCS:.c=.out)

# 宣告虛擬目標 (Phony Targets)
.PHONY: all clean help area sqrt log

# ==============================================================================
# 主要建置規則
# ==============================================================================

# 1. all: 編譯出所有的執行檔
all: $(EXECS)

# 2. Pattern Rule (模式規則 %): 簡化重複的編譯指令
# 任何名稱的 .out 都依賴於同名的 .c 檔案
# $< 代表第一個相依檔案 (原始碼 .c)
# $@ 代表目標檔案名稱 (執行檔 .out)
%.out: %.c
	$(CC) $(CFLAGS) $< -o $@ $(LDFLAGS)

# ==============================================================================
# 獨立執行目標 (Build & Run)
# ==============================================================================

# 3. area: 編譯並直接執行 area.out
area: area.out
	@echo "--- Running area.out ---"
	./area.out

# 4. sqrt: 編譯並直接執行 sqrt.out
sqrt: sqrt.out
	@echo "--- Running sqrt.out ---"
	./sqrt.out

# 5. log: 編譯並直接執行 log.out
log: log.out
	@echo "--- Running log.out ---"
	./log.out

# ==============================================================================
#  clean & help
# ==============================================================================

# 6. clean: 清除所有產生的執行檔
clean:
	rm -f $(EXECS)

# 7. help: 顯示此 Makefile 的使用說明
help:
	@echo "========================================================"
	@echo " Makefile for Exercise 2: Simple Math"
	@echo "========================================================"
	@echo " 支援的指令選項："
	@echo "  make 或 make all : 編譯並產生所有的執行檔 (.out)"
	@echo "  make area        : 編譯並執行 area.out (計算圓面積)"
	@echo "  make sqrt        : 編譯並執行 sqrt.out (計算開平方根)"
	@echo "  make log         : 編譯並執行 log.out  (計算常用對數 log10)"
	@echo "  make clean       : 清除所有產生的執行檔"
	@echo "  make help        : 顯示此說明訊息"
	@echo "========================================================"